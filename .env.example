# Cloudflare Pages AI Provider Keys
# Bu özellikleri aktif etmek için Cloudflare panelinden Environment Variables kısmına bu değişkenleri ekleyin.

GEMINI_KEY="your_gemini_api_key_here"
OPENROUTER_KEY="your_openrouter_api_key_here"
DEEPSEEK_KEY="your_deepseek_api_key_here"

# Supabase Auth & Database (Aşama 2 için Gereklidir)
# Supabase projenizdeki API settings panelinden bu bilgileri alın
VITE_SUPABASE_URL="https://[PROJECT_ID].supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_key_here"
