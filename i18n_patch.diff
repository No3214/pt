+            stroke={colors[color] || color} strokeWidth="6" strokeLinecap="round"
+            strokeDasharray={circ}
+            initial={{ strokeDashoffset: circ }}
+            animate={{ strokeDashoffset: inView ? circ * (1 - pct / 100) : circ }}
+            transition={{ duration: 1, ease: [0.16, 1, 0.3, 1] }}
